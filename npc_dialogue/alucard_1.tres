[resource]
script = ExtResource("1_bsol2")
speaker_names = Array[String](["Genya", "???", "Alucard"])
speaker_icons = Array[Texture2D]([ExtResource("2_dhu4h"), ExtResource("1_u21hv")])
lines = Array[String](["Well now. What sort of manners lead a man to sit on his brethren?", "Do not judge me for this, please. This man is my brother, and will not let me sit but on his back...", "...", "I see.", "It is indeed a very caring brother you have there.", "Of course! We must care for each other, especially when we are to spend the rest of eternity in Hell itself.", "Indeed. Since I believe this is our first meeting: I am Genya, a resident of these surroundings.", "My name is Alucard, and this is Solvar. I came here seeking an Angel's blessing. Only that could return my brother to his original form.", "You should get going then. I doubt that Angel will stay here forever.", "Indeed. Farewell!"])
line_speaker_name_index = Array[int]([0, 1, 0, 0, 0, 1, 0, 2, 0, 2])
line_speaker_icon_index = Array[int]([0, 1, 0, 0, 0, 1, 0, 1, 0, 1])
